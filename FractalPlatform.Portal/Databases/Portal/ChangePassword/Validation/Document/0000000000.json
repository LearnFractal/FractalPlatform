{
  "OldPassword": {
    "IsRequired": true,
    "MinLen": "3",
    "MaxLen": "16",
    "Formula": "@OldPassword"
  },
  "NewPassword": {
    "IsRequired": true,
    "MinLen": "3",
    "MaxLen": "16",
    "Formula": "Document.RepeatPassword = @Value"
  },
  "RepeatPassword": {
    "IsRequired": true,
    "MinLen": "3",
    "MaxLen": "16",
    "Formula": "Document.NewPassword = @Value"
  }
}