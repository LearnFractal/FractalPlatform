    {
      "Description": "Radio button choose",
      "Name": "RadioButton",
      "Dimensions": {
        "Document": "{'Control':{'Option1':true,'Option2':false}}",
        "UI": "{'ControlType':'RadioButton'}"
      },
      "Example": {
        "Control": {
          "Option1": true,
          "Option2": false
        }
      }
    },
    {
