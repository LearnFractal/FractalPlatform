if (typeof m == 'undefined') {
    var m = function () {};
    m.fn = m.prototype = {};
}

// TODO: use m.i18n
if (typeof window.tc === 'undefined') {

    window._tc = {
        uk: {
            'Type your comment and press Enter': 'Введіть Ваш коментар та натисніть Enter',
            'Your reply': 'Ваша відповідь',
            'Are you sure want remove your comment with all of possible replies': 'Ви впевнені, що хочете видалити свій коментар з усіма можливими відповідями',
            'Send': 'Надіслати',
            'Respond': 'Відповісти',
            'login': 'вхід',
            'Password': 'Пароль',
            'Your name': 'Ваше ім\'я',
            'Wait a bit': 'Зачекайте трішки',
            'Phone': 'Телефон',
            'Authorization': 'Авторизація'
        }
    };

    window.tc = (k) => {
        let lang = document.querySelector('html').getAttribute('lang') || 'uk';
        return typeof window._tc[lang] === 'undefined' || typeof window._tc[lang][k] === 'undefined' ? k : window._tc[lang][k];
    };
}

m.fn.comments = function(context) {

    let
        cookie_weua = m.cookies('weua_token') || m.cookies('authorize');

    const
        u = 'undefined',
        a = this.find('a'),
        lang = m('html').attr('lang') || 'uk',
        parent = this.parent(),
        section = parent.attr('data-section'),
        inner_id = parent.attr('data-id'),
        hash = parent.attr('data-hash'),
        auth_div = m('#auth-form'),
        auth_form = auth_div.length > 0 ? auth_div.find('form').first : null,
        // element_data = () => {
        //     return
        // },
        get_comments = (ws_c) => {

            cookie_weua = m.cookies('weua_token') || m.cookies('authorize');

            const comments_request = {
                action: 'comments',
                lang: lang,
                section: section,
                id: inner_id,
                hash: hash,
            };

            if (cookie_weua !== false && cookie_weua.length > 0) {
                comments_request.token = cookie_weua;
            }
            else if (typeof comments_request.token !== u) {
                delete comments_request.token;
            }

            ws_send(ws_c, comments_request);
        },

        /**
         * Render a main textarea with comments wrapper
         */
        comment_form = (ws_c) => {

            if (context.next('.comment-form') === false) {
                context.after('<div class="comment-form"><div placeholder="'+tc('Type your comment and press Enter')+'" contenteditable="true"></div><div class="comments-wrapper"></div></div>');
            }

            let
                form = context.next('.comment-form'),
                textarea = form.find('div[contenteditable]'),
                cookie_comment_data = m.cookies('comment_data');

            if (textarea.length === 0) {
                return false;
            }
            
            if (cookie_comment_data !== false) {

                cookie_comment_data = JSON.parse(cookie_comment_data);

                if (typeof cookie_comment_data.id !== u &&
                    cookie_comment_data.id === inner_id &&
                    typeof cookie_comment_data.comment !== u &&
                    cookie_comment_data.comment.length > 0) {

                    textarea.html(cookie_comment_data.comment);
                }
            }

            /**
             * Sending a comment by pressing Enter
             */
            textarea.on('keyup', function(e){

                const k = e.key || e.keyCode;

                if (typeof k === u || (k !== 'Enter' && k !== 13) || e.shiftKey || m(this).text().length === 0) {
                    return true;
                }

                if (this.innerHTML.trim().length === 0) {
                    return true;
                }

                const
                    closest_target = m(this).closest('[data-section][data-id]'),
                    comment_request = {
                        action: 'comments',
                        lang: lang,
                        section: closest_target.attr('data-section'),
                        id: closest_target.attr('data-id'),
                        hash: closest_target.attr('data-hash'),
                    };

                comment_request.comment = m(this).html().trim();

                this.innerHTML = '';

                cookie_weua = m.cookies('weua_token') || m.cookies('authorize');

                if (cookie_weua === false || cookie_weua.length === 0) {
                    m.cookies('comment_data', JSON.stringify(comment_request));
                    return auth_delay(comment_request);
                }

                comment_request.token = cookie_weua;

                ws_send(ws_c, comment_request);

                m.cookies('comment_data', null);
            });
        },
        validateEmail = (email) => {
            return String(email)
                .toLowerCase()
                .match(
                    /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/
                );
        },
        validatePhone = (phone) => {
            return String(phone)
                .toLowerCase()
                .match(/^[\+]?[(]?[0-9]{3}[)]?[-\s\.]?[0-9]{3}[-\s\.]?[0-9]{4,6}$/im);
        },
        text_links = (text) => {
            if (typeof text === u) return '';
            text = text.replace(/<br[\/ ]*>/gi, "<br>").trim();
            text = text.replace(/<br[\s]+style=\".*?\">/gi, "<br>");
            text = text.replace(/<br>/gi, "\n<br>\n");
            text = ' ' + text + ' ';
            text = text.replace(/[^"'>](\bhttps?:\/\/.*?\.(jpg|jpeg|png|gif|webp|svg)\b)/gmi, ' <img src="$1">');
            text = text.replace(/[^"'>](\bhttps?:\/\/www\.youtube\.com\/watch\?v=([a-z0-9\-\_]+)[&\b]*)[^"'<]*/gmi, '<br><iframe width="100%" height="280" src="https://www.youtube.com/embed/$2" frameborder="0" allowfullscreen></iframe>');
            text = text.replace(/[^"'>](\bhttps?:\/\/www\.youtube\.com\/watch.v=([a-z0-9\-\_]+)[&\b]*)[^"'<]*/gmi, '<br><iframe width="100%" height="280" src="https://www.youtube.com/embed/$2" frameborder="0" allowfullscreen></iframe>');
            text = text.replace(/[^"'>](\bhttps?:\/\/youtu\.be\/([a-z0-9\-\_]+)\b)[^"'<]*/gmi, '<br><iframe width="100%" height="280" src="https://www.youtube.com/embed/$2" frameborder="0" allowfullscreen></iframe>\n');
            text = text.replace(/[^"'>](\b(https?|ftp):\/\/[A-ZА-ЯІЇЄҐ0-9\+\-\&\@\#\/\%\?=\~_\|\!:,\.;]*[A-ZА-ЯІЇЄҐ0-9\+\-&@#\/%=~_|]\b)([^"'<])/gmi, ' <a href="$1" target="_blank">$1</a> ');
            text = text.replace(/([a-z0-9\._\-]+\@[a-z0-9\._\-]+\.[a-z0-9_\-]+)/gi, ' <a href="mailto:$1">$1</a> ');
            text = text.replace(/([\s]+)(\@[a-z0-9\-_\.]+)[^"'<]/gi, '$1<a href="/$2">$2</a> ');
            text = text.replace(/[^"'>\/](we\.ua)[^"'<\/]/gi, ' <a href="https://$1">$1</a> ');
            text = text.replace(/\n<br>\n/gi, "<br>").trim();
            text = text.replace(/<br>[\n]{0,}<br>$/gi, '');
            text = text.replace(/ ([\.;,])/gi, '$1');
            // text = text.trim();
            // text = text.replace("\n",'<br>');
            return text.trim();
        },
        build_comment = (comment, comments_wrapper) => {

            cookie_weua = m.cookies('weua_token') || m.cookies('authorize')

            let comment_options = '';

            if (typeof comment.d !== u && comment.d === true) {
                comment_options += '<a class="delete"></a>';
            }

            if (cookie_weua !== false) {
                comment_options += '<a class="reply">'+window.tc('Respond')+'</a>';
            }

            comment.comment = text_links(comment.comment);

            let
                comm_id = 'c-' + (typeof comment.short_id === u ? comment.id : comment.short_id),
                _emotions = '<div class="emotions"><a class="like active"></a><a class="heart"></a><a class="funny"></a><a class="surprised"></a><a class="sad"></a><a class="nausea"></a><a class="angry"></a></div>',
                comm = m.to_element('<div class="comment" data-id="'+comment.id+'" id="'+comm_id+'"><div class="inner"><a href="'+comment.author_path+'" class="author"><img src="'+(comment.author_avatar ?? '/data/47/no-avatar.png')+'" width="30">&nbsp;'+comment.author+'</a><small>'+comment.date+'</small>'+_emotions+comment_options+'<p>'+comment.comment+'</p></div><div class="replies"></div></div>'),
                reply = m(comm).find('a.reply'),
                del = m(comm).find('a.delete'),
                emotions_wrapper = m(comm).find('.emotions'),
                emotions_a = m(comm).find('.emotions > a'),
                reply_event = function(e) {
                    e.preventDefault();

                    const
                        closest_target = m(this).closest('[data-section][data-id]'),
                        closest_comm = m(this).closest('.comment[data-id]'),
                        replies = closest_comm.children('.replies'),
                        replies_first = replies ? m(replies.first) : null;

                    if (replies_first === null) {
                        return false;
                    }

                    const reply_data = {
                        action: 'comments',
                        lang: lang,
                        section: closest_target.attr('data-section'),
                        id: closest_target.attr('data-id'),
                        hash: closest_target.attr('data-hash'),
                    };

                    reply_data.reply_id = closest_comm.attr('data-id');

                    if (replies_first.find('div[contenteditable]').length > 0) {
                        replies_first.find('div[contenteditable]').remove();
                        return true;
                    }

                    replies_first.append(m.to_element('<div placeholder="'+tc('Your reply')+'" contenteditable></div>'));

                    replies_first.find('div[contenteditable]').on('keyup keypress', function(e){

                        const
                            k = event.key || event.keyCode,
                            m_this = m(this);

                        if (typeof k !== u && (k === 'Enter' || k === 13) && !event.shiftKey && m_this.text().length > 0) {

                            reply_data.comment = m_this.html().trim();

                            this.innerHTML = '';

                            cookie_weua = m.cookies('weua_token') || m.cookies('authorize');

                            if (cookie_weua === false || cookie_weua.length === 0) {
                                return auth_delay(reply_data);
                            }

                            reply_data.token = cookie_weua;

                            ws_send(window.ws, reply_data);

                            m_this.remove();
                        }
                        else if (m_this.class('has-typing') === false) {

                            ws_send(window.ws, {action: 'comments', typing_id: closest_comm.attr('data-id')});

                            m_this.class({'has-typing': true});
                        }


                    }).first.focus();
                };

            if (del.length !== 0) {
                del.on('click', function(e){
                    e.preventDefault();

                    if (!confirm(tc('Are you sure want remove your comment with all of possible replies')+'?')) {
                        return false;
                    }

                    const
                        closest_target = m(this).closest('[data-section][data-id]'),
                        del_request = {
                            action: 'comments',
                            lang: lang,
                            section: closest_target.attr('data-section'),
                            id: closest_target.attr('data-id'),
                            hash: closest_target.attr('data-hash'),
                            delete_comment: comment.id,
                            token: cookie_weua
                        };

                    ws_send(window.ws, del_request);
                });
            }

            if (reply.length !== 0) {
                reply.on('click', reply_event);
            }

            if (emotions_a.length !== 0) {
                emotions_a.on('click', function(e){

                    e.preventDefault();

                    const
                        closest_comm = m(this).closest('.comment[data-id]'),
                        // comments_context = m(this).closest('.comment-form').prev('[data-m-action="comments"]'),
                        emotion_data = {
                            action: 'comments',
                            emotion_comment_id: closest_comm.attr('data-id'),
                            emotion: m(this).attr('class').replace(' active', '').replace(' e', '').trim()
                        },
                        cookie_weua = m.cookies('weua_token') || m.cookies('authorize');

                    if (cookie_weua === false || cookie_weua.length === 0) {
                        return auth_delay(emotion_data);
                    }

                    emotion_data.token = cookie_weua;

                    ws_send(window.ws, emotion_data);
                });
            }

            if (emotions_wrapper.length > 0 && typeof comment.emotions === 'object') {

                let
                    emotions = ['like','heart','funny','surprised','sad','nausea','angry'],
                    largest_emotion = null;

                if (comment.emotions === null) {
                    comment.emotions = {};
                }

                emotions.forEach(function(emotion_name){
                    if (typeof comment.emotions[emotion_name] === u) {
                        comment.emotions[emotion_name] = 0;
                    }
                });

                Object.keys(comment.emotions).forEach(function(emotion) {
                    if (parseInt(comment.emotions[emotion]) === 0) {
                        emotions_wrapper.find('a.' + emotion).text('');
                        return true;
                    }
                    emotions_wrapper.find('a.' + emotion).class({active: true, e: true}).text(comment.emotions[emotion]);
                    largest_emotion = largest_emotion == null ? emotion : largest_emotion;
                });

                emotions_wrapper.find('a.active').class({active: null});
                emotions_wrapper.find('a.e').class({e: null});

                if (largest_emotion !== null) {
                    emotions_wrapper.find('a.' + largest_emotion).class({active: true, e: true});
                    emotions_wrapper.class({'has-active': true});
                }
                else {
                    emotions_wrapper.find('a:first-child').class({active: true});
                    emotions_wrapper.class({'has-active': null});
                }
            }

            /*
            comments_wrapper.prepend(comm);
            */
            comments_wrapper.append(comm);
        },

        ping = () => {
            return typeof window.ws !== u && window.ws.send('');
        },

        ping_interval_init = () => {
            if (typeof window.ws_ping_interval !== u) {
                clearInterval(window.ws_ping_interval);
            }
            window.ws_ping_interval = setInterval(ping, 60000);
        },

        process_comments_data = function(data){

            data = data.data;

            if (typeof window.ws_get_comments !== u) {
                delete window.ws_get_comments;
            }

            if (typeof data === u || data.length === 0 || data === 'pong') {
                return;
            }

            ping_interval_init();

            let records = JSON.parse(data);

            if (typeof records !== u && typeof records.data !== u && typeof records.data.count_comments !== u) {

                for (let c = 0; c < records.data.count_comments.length; c++) {

                    const record = records.data.count_comments[c];

                    if (typeof record.id === u && typeof record.hash === u) {
                        continue;
                    }

                    let _comments;

                    if (typeof record.id !== u) {
                        _comments = m('[data-id="'+record.id+'"] .comments');
                    }
                    else if (typeof record.hash !== u) {
                        _comments = m('[data-hash="'+record.hash+'"] .comments');
                    }

                    let a = _comments === u ? [] : _comments.find('a'),
                        a_count;

                    if (a.length === 0) {
                        continue;
                    }

                    a_count = a.find('.count');

                    if (record.count === '+1') {
                        a.class({e: true});
                        if (a_count.text().trim().length === 0) {
                            a_count.text('1');
                        }
                        else {
                            a_count.text(Math.max(parseInt(a_count.text()), 0) + 1);
                        }
                    }
                    else if (parseInt(record.count) !== 0) {
                        a.class({e: true});
                        a_count.text(record.count.toString());
                    }
                    else {
                        a.class({e: null});
                        a_count.text('');
                    }
                }
            }

            if (typeof records !== u && typeof records.data !== u && typeof records.data.comment_emotions !== u) {
                let comment_emotions = records.data.comment_emotions;

                for (let ce = 0; ce < comment_emotions.length; ce++) {

                    if (typeof comment_emotions[ce].comment_id === u) {
                        continue;
                    }

                    let
                        emotions = ['like','heart','funny','surprised','sad','nausea','angry'],
                        record = comment_emotions[ce],
                        emotions_wrapper = m('[data-id="'+record.comment_id+'"] > .inner > .emotions'),
                        largest_emotion = null;

                    if (emotions_wrapper.length === 0 || typeof record.emotions !== 'object') {
                        continue;
                    }

                    if (record.emotions === null) {
                        record.emotions = {};
                    }

                    emotions.forEach(function(emotion_name){
                        if (typeof record.emotions[emotion_name] === u) {
                            record.emotions[emotion_name] = 0;
                        }
                    });

                    Object.keys(record.emotions).forEach(function(emotion) {
                        if (parseInt(record.emotions[emotion]) === 0) {
                            emotions_wrapper.find('a.' + emotion).text('');
                            return true;
                        }
                        emotions_wrapper.find('a.' + emotion).class({active: true, e: true}).text(record.emotions[emotion]);
                        largest_emotion = largest_emotion == null ? emotion : largest_emotion;
                    });

                    emotions_wrapper.find('a.active').class({active: null});
                    emotions_wrapper.find('a.e').class({e: null});

                    if (largest_emotion !== null) {
                        emotions_wrapper.find('a.' + largest_emotion).class({active: true, e: true});
                        emotions_wrapper.class({'has-active': true});
                    }
                    else {
                        emotions_wrapper.find('a:first-child').class({active: true});
                        emotions_wrapper.class({'has-active': null});
                    }
                }
            }

            if (typeof records !== u && typeof records.data !== u && typeof records.data.comments !== u && typeof records.data.section !== u) {
                let
                    comments = [],
                    replies = [];

                for (let rdc = 0; rdc < records.data.comments.length; rdc++) {

                    const cmmnt = records.data.comments[rdc];

                    if (typeof cmmnt.id === u && typeof cmmnt.hash === u) {
                        continue;
                    }

                    if (typeof cmmnt.reply !== u && cmmnt.reply !== null && cmmnt.reply.length > 0) {
                        replies.push(cmmnt);
                    }
                    else {
                        comments.push(cmmnt);
                    }

                    delete records.data.comments[rdc];
                }


                if (comments.length > 0) {
                    for (let c = 0; c < comments.length; c++) {

                        const comment = comments[c];

                        let comments_wrapper = [];

                        if (typeof records.data.id !== u) {
                            comments_wrapper = m('[data-section="' + records.data.section + '"][data-id="' + records.data.id + '"] .comment-form > .comments-wrapper');
                        }
                        else if (typeof records.data.hash !== u) {
                            comments_wrapper = m('[data-section="' + records.data.section + '"][data-hash="' + records.data.hash + '"] .comment-form > .comments-wrapper');
                        }
                        else {
                            continue;
                        }

                        if (comments_wrapper.length === 0 || typeof comment.comment === u) {
                            continue;
                        }

                        if (comments_wrapper.find('i.typing').length > 0) {
                            comments_wrapper.find('i.typing').remove();
                        }

                        if (comments_wrapper.find('.comment[data-id="' + comment.id + '"]').length === 0) {
                            build_comment(comment, comments_wrapper);
                        }
                    }
                }

                if (replies.length > 0) {

                    replies.forEach((reply) => {
                        let parent_comment;

                        if (typeof records.data.id !== u) {
                            parent_comment = m('[data-section="' + records.data.section + '"][data-id="' + records.data.id + '"] .comment[data-id="' + reply.reply + '"]');
                        }
                        else if (typeof records.data.hash !== u) {
                            parent_comment = m('[data-section="' + records.data.section + '"][data-hash="' + records.data.hash + '"] .comment[data-id="' + reply.reply + '"]');
                        }
                        else {
                            return true;
                        }

                        if (parent_comment.length === 0 || typeof reply.reply === u) {
                            return true;
                        }

                        let replies_wrapper = m(parent_comment.children('.replies').first);

                        if (replies_wrapper.length === 0) {
                            return true;
                        }

                        if (replies_wrapper.find('i.typing').length > 0) {
                            replies_wrapper.find('i.typing').remove();
                        }

                        if (replies_wrapper.find('.comment[data-id="' + reply.id + '"]').length === 0) {
                            build_comment(reply, replies_wrapper);
                        }
                    });
                }
            }

            if (typeof records !== u && typeof records.data !== u && typeof records.data.delete_comment !== u) {
                let comment_id = records.data.delete_comment,
                    comment_div = m('.comment[data-id="'+comment_id+'"]');

                if (comment_div.length > 0) {
                    comment_div.remove();
                }
            }

            if (typeof records !== u && typeof records.data !== u && typeof records.data.typing_id !== u) {
                let comment_id = records.data.typing_id,
                    replies_div = m('.comment[data-id="'+comment_id+'"] > .replies');

                if (replies_div.length > 0 && replies_div.find('div[contenteditable]').length === 0 && replies_div.find('i.typing').length === 0) {
                    let typing = m.to_element('<i class="typing"></i>');

                    replies_div.prepend(typing);

                    window.setTimeout(function(){
                        typing.remove();
                    }, 5000);
                }
                /**
                 This code allows to remove a class 'has-typing' in text-area and allows to send a web-hook again from that field
                 Another words, this code refresh a dely from div[contenteditable]
                 **/
                else if (replies_div.length > 0 && replies_div.find('div[contenteditable].has-typing').length > 0) {
                    window.setTimeout(function(){
                        replies_div.find('div[contenteditable].has-typing').class({'has-typing': null});
                    }, 5000);
                }
            }

            if (window.location.hash.length > 0 && window.location.hash.substr(1).match(/^comment[a-z0-9]{24}$/) !== null) {
                let
                    hash_comment_id = window.location.hash.replace('#comment',''),
                    hash_comment = m('.comment[data-id="'+hash_comment_id+'"]');

                if (hash_comment.length > 0) {
                    hash_comment.scroll_to(-80);
                }
                else {
                    window.history.pushState((history.state || {}), null, window.location.pathname);
                }
            }
            else if (window.location.hash.length > 0 && window.location.hash.substr(1).match(/^c\-[a-z0-9]{6,9}$/) !== null) {
                let
                    hash_comment_id = window.location.hash.replace('#c-',''),
                    hash_comment = m('.comment[id="c-'+hash_comment_id+'"]');

                if (hash_comment.length > 0) {
                    hash_comment.scroll_to(-80);
                }
                else {
                    window.history.pushState((history.state || {}), null, window.location.pathname);
                }
            }
        },
        get_comments_counts = (ws_c) => {

            // Prevent multiple requests for obtain an amount of comments
            if (typeof window.ws_get_comments !== u) return;
            window.ws_get_comments = true;

            const count_request = {
                action: 'comments',
                lang: lang,
                token: m.cookies('weua_token') || m.cookies('authorize'),
                ids: [],
                section: [],
            };

            let comments_ids = m('[data-id] > [data-m-action="comments"]:not(.ws-used)');

            if (comments_ids.length > 0) {

                comments_ids.each(function() {
                    const parent_with_id = m(this).closest('[data-id][data-section]');
                    if (parent_with_id === false) return true;
                    count_request.ids.push(parent_with_id.attr('data-id').trim());
                    const sect = parent_with_id.attr('data-section').trim();
                    if (!count_request.section.includes(sect)) {
                        count_request.section.push(sect);
                    }
                });

                comments_ids.class('ws-used', true);

                ws_send(ws_c, count_request);
            }
        },
        attempt_connection = (socket) => {
            return new Promise((resolve, reject) => {
                const
                    attempts = 6,
                    delay = 500;

                let attempt = 0;

                const interval = window.setInterval(() => {

                    if (attempt >= attempts) {
                        window.clearInterval(interval);
                        reject(new Error('attempt ' + attempt))
                    }
                    else if (socket.readyState === socket.OPEN) {
                        window.clearInterval(interval);
                        resolve();
                    }

                    attempt++

                }, delay);
            })
        },
        ws_send = async (ws, msg) => {

            if (typeof ws === u || ws === null) {
                ws_init().then((ws_c) => {
                    ws_send(ws_c, msg);
                });
                return true;
            }

            if (ws.readyState === ws.OPEN) {
                ws.send(JSON.stringify(msg));
                return true;
            }

            try {
                await attempt_connection(ws);
                ws.send(JSON.stringify(msg));
            }
            catch (err) {
                console.error(err);
            }
        },
        ws_connect = () => {
            window.ws = new WebSocket('wss://we.ua:2053');
        },
        ws_reconnect = () => {

            if (typeof window.ws_reconnect_comments !== u) return;

            delete window.ws;
            delete window.ws_emotions_events;

            /** Trying to connect every 10 seconds */
            window.ws_reconnect_comments = setInterval(() => {

                /** Step2: (after previous 10 seconds) call a ws_init() if connection is success */
                if (typeof window.ws !== u && window.ws.readyState < 2) {

                    window.clearInterval(window.ws_reconnect_comments);

                    delete window.ws_reconnect_comments;

                    ws_init().then(get_comments_counts);

                    return;
                }

                /** Step1: trying to connect again */
                ws_connect();

            }, 10000);
        },

        ws_init_events = () => {

            // Prevent listeners multiple init
            if (typeof window.ws_comments_events !== u) return;
            window.ws_comments_events = true;

            window.ws.removeEventListener('open', ping_interval_init);
            window.ws.addEventListener('open', ping_interval_init);

            window.ws.removeEventListener('close', ws_reconnect);
            window.ws.addEventListener('close', ws_reconnect);

            window.ws.removeEventListener('message', process_comments_data);
            window.ws.addEventListener('message', process_comments_data);
        },

        ws_init = () => {

            // WebSocket can be initiated in another module
            if (typeof window.ws !== u && window.ws.readyState < 2) {
                ws_init_events();

                return Promise.resolve(window.ws);
            }

            // Initiate a new WebSocket instance and make it available globally
            return new Promise((resolve, reject) => {

                ws_connect();

                window.ws.addEventListener('open', () => {
                    resolve(window.ws);
                });

                window.ws.addEventListener('error', (err) => {
                    reject(err);
                });

                ws_init_events();
            });
        },
        auth_delay = (comment_request) => {

            if (auth_form === null) {
                return false;
            }

            m('.modal .title').html(tc('Authorization'));

            if (typeof auth_form.data === u) {
                auth_form.data = {};
            }

            auth_form.data.onsuccess = function(token) {

                comment_request.token = token;

                ws_init().then((ws_c) => {
                    ws_send(ws_c, {action: 'auth', token: token});
                    ws_send(ws_c, comment_request);

                    // Trying to get a comments counts
                    get_comments_counts(ws_c);
                });

                m.cookies('comment_data', null);
            };

            m.modal(auth_div);

            return true;
        };

    // Set a CSS class `active` to comments icon
    m(a.first).class({active: true});

    ws_init().then((ws_c) => {

        // Trying to get a comments counts
        get_comments_counts(ws_c);

        // Automatically open all of comments if wrapper has a specific attribute
        if (context.attr('data-m-autoload') === 'true') {
            comment_form(ws_c);
            get_comments(ws_c);
        }
        // Casual way: Customer should click on comments icon
        else {
            a.on('click', function(e){

                e.preventDefault();

                if (context.next('.comment-form') !== false) {
                    context.next('.comment-form').remove();
                    return false;
                }

                comment_form(ws_c);
                get_comments(ws_c);
            });
        }
    });
};