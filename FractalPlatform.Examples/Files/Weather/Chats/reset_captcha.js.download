if (typeof m == 'undefined') {
    var m = function () {};
    m.fn = m.prototype = {};
}

m.fn.reset_captcha = function(img) {
    this.on('click', function(e){
        e.preventDefault();
        var unique_id = m(img).next('input[type="hidden"][name="captcha_unique_id"]');
        m.ajax({
            url: this.getAttribute('data-url') || window.location.pathname,
            data: {
                action: '_ajax_get_captcha',
                unique_id: unique_id.length > 0 ? unique_id.val() : null
            },
            success: function(data) {
                if (typeof data.captcha_unique_id !== 'undefined' && unique_id.length > 0) {
                    unique_id.val(data.captcha_unique_id);
                }
                if (typeof data.captcha_image !== 'undefined') {
                    m(img).attr('src', 'data:image/png;base64,' + data.captcha_image);
                }
            }
        });
    });
    this.css({cursor: 'pointer'});
};