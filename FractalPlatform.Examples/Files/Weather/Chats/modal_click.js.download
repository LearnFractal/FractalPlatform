if (typeof m === 'undefined') {
    var m = function () {};
    m.fn = m.prototype = {};
}

m.fn.modal_click = function(context) {

    return this.on('click', function(e){

        e.preventDefault();

        if (m('.modal.active .close').length > 0) {
            m('.modal.active .close').event_fire('click');
            //return true;
        }

        if (m(this).attr('data-m-title') !== null) {
            m('.modal .title').html(m(this).attr('data-m-title'));
        }

        context.on('modal_opened', function(){

            if (context.find('[data-close="modal"]').length > 0) {
                context.find('[data-close="modal"]').off('click').on('click', function(e){
                    e.preventDefault();
                    m.modal(context);
                });
            }
        });

        m.modal(context);
    });
};