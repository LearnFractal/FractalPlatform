if (typeof m == 'undefined') {
    var m = function () {};
    m.fn = m.prototype = {};
}

m.fn.share = function(context) {

    let
        lang = m('html').attr('lang') || 'uk',
        host = window.location.hostname,
        services = {
            facebook: 'https://www.facebook.com/sharer/sharer.php?u=~link~',
            twitter: 'https://twitter.com/home?status=~link~',
            linkedin: 'https://www.linkedin.com/shareArticle?mini=true&url=~link~',
            viber: 'viber://forward?text=~link~',
            whatsapp: 'whatsapp://send?text=~link~',
            /* telegram: 'https://t.me/share/url?url=~link~', */
            we: 'https://'+host+'/share?url=~link~',
        },
        _t = {
            uk: {
                'Share': 'Поділитись'
            },
            ru: {
                'Share': 'Поделиться'
            }
        },
        t = function(k){
            return typeof _t[lang] === 'undefined' || typeof _t[lang][k] === 'undefined' ? k : _t[lang][k];
        },
        capitalizeFirstLetter = function (string) {
            return string.charAt(0).toUpperCase() + string.slice(1);
        },
        /* post_item = m(this).closest('.post-item'), */
        share_link = m(this).attr('data-link') || '';

    context.append('<a class="icon active" title="'+t('Share')+'"></a>');

    for (let s in services) {
        let link = services[s].replace('~link~', share_link.toString()),
            title = s === 'we' ? 'weua' : capitalizeFirstLetter(s);

        link = link.replace(/~.*~/g, '');

        context.append('<a class="'+s+'" title="'+title+'" href="'+link+'" target="_blank"></a>');
    }
};