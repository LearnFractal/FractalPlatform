if (typeof m === 'undefined') {
    var m = function () {};
    m.fn = m.prototype = {};
}

m.fn.emotions = function(context) {

    let
        a,
        cookie_weua = m.cookies('weua_token') || m.cookies('authorize');

    const
        u = 'undefined',
        lang = m('html').attr('lang') || 'uk',
        parent = this.closest('[data-section][data-id]'),
        section = !parent ? null : parent.attr('data-section'),
        inner_id = !parent ? null : parent.attr('data-id'),
        hash = !parent ? null : parent.attr('data-hash'),
        emotions_names = {
            like: 'Like',
            dislike: 'Dislike',
            heart: 'Very like it',
            funny: 'Very funny',
            surprised: 'Surprised',
            sad: 'Very sad',
            nausea: 'Facepalm',
            angry: 'Infuriating'
        },
        _t = {
            uk: {
                'Like': 'Вподобайка',
                'Dislike': 'Дизлайк',
                'Very like it': 'ДУЖЕ подобається',
                'Very funny': 'Дуже смішно',
                'Surprised': 'Здивувало',
                'Very sad': 'Співчуваю / Прикро',
                'I\'m nauseated from this': 'Мене нудить від цього',
                'Facepalm': 'Як соромно...',
                'Infuriating': 'Обурливо / Не припустимо',
                'login' : 'вхід',
                'Password': 'Пароль',
                'Your name': 'Ваше ім\'я',
                'Wait a bit': 'Зачекайте трішки',
                'Phone': 'Телефон',
                'Authorization': 'Авторизація'
            },
            ru: {
                'Like': 'Мне это нравится',
                'Dislike': 'Мне это не нравится',
                'Very like it': 'ОЧЕНЬ нравится',
                'Very funny': 'Это очень смешно',
                'Surprised': 'Меня это удивило',
                'Very sad': 'Это очень печально',
                'I\'m nauseated from this': 'Меня тошнит от этого',
                'Facepalm': 'Как стыдно...',
                'Infuriating': 'Это меня разозлило',
                'login' : 'вход',
                'Password': 'Пароль',
                'Your name': 'Ваше имя',
                'Wait a bit': 'Подождите немного',
                'Phone': 'Телефон',
                'Authorization': 'Ауторизация'
            }
        },
        t = function(k){
            return typeof _t[lang] === u || typeof _t[lang][k] === u ? k : _t[lang][k];
        },
        custom_emotions = m(this).attr('data-m-emotions') !== null ? m(this).attr('data-m-emotions').split(',') :
            ['like','heart','funny','surprised','sad','nausea','angry'],
        validateEmail = (email) => {
            return String(email)
                .toLowerCase()
                .match(
                    /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/
                );
        },
        validatePhone = (phone) => {
            return String(phone)
                .toLowerCase()
                .match(/^[\+]?[(]?[0-9]{3}[)]?[-\s\.]?[0-9]{3}[-\s\.]?[0-9]{4,6}$/im);
        },
        emotion_data = () => {
console.log(section);
            return {
                section: section,
                id: inner_id,
                hash: hash,
            }
        },
        a_click = function(e) {

            e.preventDefault();

            /*
            if (typeof window.ws === u) {
                return false;
            }
            */

            const data = emotion_data();

            data.action = 'emotions';
            data.emotion = m(this).attr('class').replace(' active', '').replace(' e', '').trim();

            cookie_weua = m.cookies('weua_token') || m.cookies('authorize');

            if (cookie_weua === false || cookie_weua.length === 0) {
                return auth_delay(data);
            }

            data.token = cookie_weua;
            ws_send(window.ws, JSON.stringify(data));
        },

        ping = () => {
            return typeof window.ws !== u && window.ws.send('');
        },

        ping_interval_init = () => {
            if (typeof window.ws_ping_interval !== u) {
                clearInterval(window.ws_ping_interval);
            }
            window.ws_ping_interval = setInterval(ping, 60000);
        },

        process_emotions_data = function(data){

            data = data.data;

            if (typeof window.ws_get_emotions !== u) {
                delete window.ws_get_emotions;
            }

            if (typeof data === u || data.length === 0 || data === 'pong') {
                return false;
            }

            ping_interval_init();

            let records = JSON.parse(data);

            if (typeof records === u || typeof records.data === u || typeof records.data.emotions === u) {
                return false;
            }

            const items = records.data.emotions;

            records.data.emotions.forEach((item) => {

                let container,
                    largest_emotion = null;

                if (typeof item.id !== u && typeof item.section !== u) {
                    container = m('[data-section="'+item.section+'"][data-id="'+item.id+'"] [data-m-action="emotions"]');
                }
                else if (item.hash !== u && typeof item.section !== u) {
                    container = m('[data-section="'+item.section+'"][data-hash="'+item.hash+'"] [data-m-action="emotions"]');
                }

                if (typeof container === u || container.length === 0 || typeof item.emotions !== 'object') {
                    return;
                }

                /** Pre-process all of emotions in `emotions` object */
                Object.keys(emotions_names).forEach(function(emotion_name){
                    if (typeof item.emotions === u || item.emotions == null) {
                        item.emotions = {};
                    }
                    if (typeof item.emotions[emotion_name] === u) {
                        item.emotions[emotion_name] = 0;
                    }
                });

                Object.keys(item.emotions).forEach(function(emotion) {

                    if (parseInt(item.emotions[emotion]) === 0) {
                        container.find('a.' + emotion).text('');
                        return true;
                    }

                    container.find('a.' + emotion).class({active: true, e: true}).text(item.emotions[emotion]);

                    largest_emotion = largest_emotion == null ? emotion : largest_emotion;
                });

                container.find('a.active').class({active: null});
                container.find('a.e').class({e: null});

                if (largest_emotion !== null) {
                    container.find('a.' + largest_emotion).class({active: true, e: true});
                    container.class({'has-active': true});
                }
                else {
                    container.find('a:first-child').class({active: true});
                    container.class({'has-active': null});
                }
            });
        },
        get_emotions_by_ids = (ws_e) => {

            if (typeof window.ws_get_emotions !== u) return;
            window.ws_get_emotions = true;

            let
                emotions_data = {
                    action: 'emotions',
                    lang: lang,
                    section: [],
                    ids: [],
                    token: m.cookies('weua_token') || m.cookies('authorize')
                },
                emotions_ids = m('[data-id] [data-m-action="emotions"]:not(.ws-used)');

            if (emotions_ids.length > 0) {

                emotions_ids.each(function() {
                    const parent_with_id = m(this).closest('[data-id][data-section]');
                    if (parent_with_id === false) return true;
                    const sect = parent_with_id.attr('data-section').trim();
                    emotions_data.ids.push(parent_with_id.attr('data-id').trim());
                    if (!emotions_data.section.includes(sect)) {
                        emotions_data.section.push(sect);
                    }
                });

                emotions_ids.class('ws-used', true);

                ws_send(ws_e, JSON.stringify(emotions_data));
            }
        },
        attempt_connection = (socket) => {
            return new Promise((resolve, reject) => {
                const
                    attempts = 6,
                    delay = 500;

                let attempt = 0;

                const interval = window.setInterval(() => {

                    if (attempt >= attempts) {
                        window.clearInterval(interval);
                        reject(new Error('attempt ' + attempt))
                    }
                    else if (socket.readyState === socket.OPEN) {
                        window.clearInterval(interval);
                        resolve();
                    }

                    attempt++

                }, delay);
            })
        },
        ws_send = async (ws, msg) => {

            if (typeof ws === u || ws === null) {
                ws_init().then((ws_c) => {
                    ws_send(ws_c, msg);
                });
                return true;
            }

            if (ws.readyState === ws.OPEN) {
                ws.send(msg);
                return true;
            }

            try {
                await attempt_connection(ws);
                ws.send(msg);
            }
            catch (error) {
                console.error(error);
            }
        },
        ws_connect = () => {
            window.ws = new WebSocket('wss://we.ua:2053');
        },
        ws_reconnect = () => {

            if (typeof window.ws_reconnect_emotions !== u) return;

            delete window.ws;
            delete window.ws_emotions_events;

            /** Trying to connect every 10 seconds */
            window.ws_reconnect_emotions = setInterval(() => {

                /** Step2: (after previous 10 seconds) call a ws_init() if connection is success */
                if (typeof window.ws !== u && window.ws.readyState < 2) {

                    window.clearInterval(window.ws_reconnect_emotions);

                    delete window.ws_reconnect_emotions;

                    ws_init().then(get_emotions_by_ids);

                    return;
                }

                /** Step1: trying to connect again */
                ws_connect();

            }, 10000);
        },
        ws_init_events = () => {

            // Prevent listeners multiple init
            if (typeof window.ws_emotions_events !== u) return;
            window.ws_emotions_events = true;

            window.ws.removeEventListener('open', ping_interval_init);
            window.ws.addEventListener('open', ping_interval_init);

            window.ws.removeEventListener('close', ws_reconnect);
            window.ws.addEventListener('close', ws_reconnect);

            window.ws.removeEventListener('message', process_emotions_data);
            window.ws.addEventListener('message', process_emotions_data);
        },
        ws_init = function() {

            // WebSocket can be initiated in another module
            if (typeof window.ws !== u && window.ws.readyState < 2) {
                ws_init_events();

                return Promise.resolve(window.ws);
            }

            // Initiate a new WebSocket instance and make it available globally
            return new Promise((resolve, reject) => {

                ws_connect();

                window.ws.addEventListener('open', () => {
                    resolve(window.ws);
                });

                window.ws.addEventListener('error', (err) => {
                    reject(err);
                });

                ws_init_events();
            });
        },
        auth_div = m('#auth-form'),
        auth_form = auth_div.length > 0 ? auth_div.find('form').first : null,
        auth_delay = (emotion_data) => {

            if (auth_form === null) {
                return false;
            }

            m('.modal .title').html(tc('Authorization'));

            if (typeof auth_form.data === u) {
                auth_form.data = {};
            }

            auth_form.data.onsuccess = (token) => {

                emotion_data.token = token;

                ws_init().then((ws_e) => {
                    ws_send(ws_e, JSON.stringify({action: 'auth', token: token}));
                    ws_send(ws_e, JSON.stringify(emotion_data));
                });
            };

            m.modal(auth_div);

            return true;
        };

    for (let k in emotions_names) {

        if (custom_emotions.length > 0 && custom_emotions.indexOf(k) === -1) {
            continue;
        }

        context.append('<a class="' + k + '" title="' + t(emotions_names[k]) + '"></a>');
    }

    a = context.find('a');

    m(a.first).class({active: true});

    ws_init().then((ws_e) => {

        a.on('click', a_click);

        get_emotions_by_ids(ws_e);
    });
};