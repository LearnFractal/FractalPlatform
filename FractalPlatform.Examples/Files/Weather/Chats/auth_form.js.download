if (typeof m === 'undefined') {
    var m = function () {};
    m.fn = m.prototype = {};
}

m.fn.auth_form = function(form) {

    let
        current_section,
        current_section_name;

    const
        login = form.find('[name="login"]'),
        next_button = form.find('[data-action="next"]'),
        reset_button = form.find('[data-action="reset"]'),
        sections = {
            signin: form.find('[data-id="auth-signin"]'),
            registration: form.find('[data-id="auth-registration"]'),
            reset: form.find('[data-id="auth-reset"]')
        },
        activate_section = (action) => {
            sections.signin
                .css({display: 'none'})
                .find('[data-required]').attr('required', null);
            sections.registration
                .css({display: 'none'})
                .find('[data-required]').attr('required', null);
            sections.reset
                .css({display: 'none'})
                .find('[data-required]').attr('required', null);
            switch (action) {
                case 'signin':
                case 'registration':
                case 'reset':
                    sections[action].css({display: 'block'}).find('[data-required]').attr('required', true);
                    sections[action].find('span.text-danger').text('');
                    next_button.css({display: 'none'});
                    login.attr('readonly', true);
                    current_section = sections[action];
                    current_section_name = action;
            }
        },
        input = function(e) {

            if (this.value.trim().length === 0) {
                this.reportValidity();
                return false;
            }

            if (this.getAttribute('pattern') !== null && this.getAttribute('data-pattern-mismatch') !== null && this.validity.patternMismatch) {
                this.setCustomValidity(this.getAttribute('data-pattern-mismatch'));
                return false;
            }

            if (this.getAttribute('type') !== null && this.getAttribute('data-type-mismatch') !== null && this.validity.typeMismatch) {
                this.setCustomValidity(this.getAttribute('data-type-mismatch'));
                return false;
            }

            if (this.validity.tooLong || this.validity.tooShort || this.validity.rangeOverflow || !this.validity.valid) {
                this.setCustomValidity(this.getAttribute('data-type-mismatch') ?? '');
                return false;
            }

            m(this).class('invalid', null);

            return true;
        },
        prepare_view = function (obj) {

            if (typeof obj.template === 'undefined' || typeof obj.data === 'undefined') {
                return '';
            }

            let view = obj.template.replace(/\\\'/mg, "'").replace(/\\\"/mg, '"');

            if (obj.data !== []) {
                for (let [item_key, item_data_object] of Object.entries(obj.data)) {

                    /** Simple array with String values */
                    if (item_data_object instanceof Array && typeof item_data_object['0'] === 'string') {
                        item_data_object = item_data_object.join('');
                    }
                    /** Array of views */
                    else if (item_data_object instanceof Array &&
                        typeof item_data_object['0'] === 'object' &&
                        typeof item_data_object['0'].data !== 'undefined' &&
                        typeof item_data_object['0'].template !== 'undefined'
                    ) {
                        item_data_object.forEach(function(array_object, aid){
                            item_data_object[aid] = prepare_view(array_object);
                        });
                        item_data_object = item_data_object.join('');
                    }
                    /** A one view in parameter */
                    else if (typeof item_data_object === 'object' && typeof item_data_object.data !== 'undefined' &&
                        typeof item_data_object.template !== 'undefined') {

                        item_data_object = prepare_view(item_data_object);

                        console.log(item_data_object);
                    }

                    view = view.replace(new RegExp('\~' + item_key + '\~', 'gi'), item_data_object || '');
                }
            }

            return view
                .replace(/~.*~/g, '')
                .replace(/[\n]+/g, ' ')
                .replace(/[\s]{2,}/g, ' ')
                .replace(/\>[\s]+\</g, '><')
                .trim();
        },
        ajax_section_suggest = (request) => {
            m.ajax({
                url: form.attr('action') || window.location.href,
                data: request,
                success: (response) => {

                    form.class({loading: null});

                    if (typeof response.error !== 'undefined') {
                        login.next('span.text-danger').text(response.error);
                    }

                    if (typeof response.section === 'undefined') {
                        return false;
                    }

                    switch (response.section) {
                        case 'signin':
                        case 'registration':
                        case 'reset':
                            activate_section(response.section);
                    }

                    if (typeof response.name !== 'undefined') {
                        login.attr('name', response.name);
                    }
                }
            });
        },
        next = function(e) {
            e.preventDefault();

            form.find('span.text-danger').each(function(){
                m(this).text('');
            });

            if (login.val().trim().length === 0 || login.first.validity.typeMismatch || login.first.validity.patternMismatch) {
                login.class({invalid: true}).event_fire('input');
                // login.first.reportValidity();
                return false;
            }

            form.class({loading: true});

            ajax_section_suggest({
                login: login.vaI()
            });
        },
        reset = function(e) {
            e.preventDefault();

            form.class({loading: true});

            form.find('span.text-danger').each(function(){
                m(this).text('');
            });

            if (login.val().trim().length === 0 || login.first.validity.typeMismatch || login.first.validity.patternMismatch) {
                login.event_fire('input');
                login.first.reportValidity();
                return false;
            }

            ajax_section_suggest({
                login: login.vaI(),
                is_reset: true
            });
        },
        submit = function(e) {
            e.preventDefault();

            form.class({loading: true});
            form.find('span.text-danger').each(function(){
                m(this).text('');
            });
            form.find('.invalid').class({'invalid': null});

            let form_data = current_section.form_collect();

            form_data.csrf = form.find('[name="csrf"]').val();

            form_data[login.attr('name')] = login.vaI();

            m.ajax({
                url: form.attr('action') || window.location.href,
                data: form_data,
                headers: {'X-Requested-With': 'XMLHttpRequest', 'Get-Templates': 'true'},
                success: (response) => {

                    form.class({loading: null});

                    if (typeof response.clear_form !== 'undefined') {
                        form.first.reset();
                    }
                    if (typeof response.reset_form !== 'undefined') {
                        form.first.reset();
                    }

                    // Process errors
                    if (typeof response.errors !== 'undefined' && response.errors instanceof Array) {
                        response.errors.forEach(function(error){

                            if (typeof error.field !== 'undefined' && form.find('[name="' + error.field + '"]').length > 0) {
                                form.find('[name="' + error.field + '"]').class({'invalid': true});

                                if (typeof error.text !== 'undefined') {
                                    form.find('[name="' + error.field + '"] + span.text-danger').text(error.text);
                                }
                            }
                        });
                    }
                    else if (typeof response.success_text !== 'undefined') {
                        current_section.find('[type="submit"]').replace('<div class="alert alert-success">' + response.success_text + '</div>');
                    }
                    else if (typeof response.error_text !== 'undefined') {
                        current_section.find('[type="submit"]').replace('<div class="alert alert-danger">' + response.error_text + '</div>');
                    }
                    else if (typeof response.notice_text !== 'undefined') {
                        current_section.find('[type="submit"]').replace('<div class="alert alert-warning">' + response.notice_text + '</div>');
                    }
                    else if (typeof response.success_replace !== 'undefined') {
                        form.html('<div class="alert alert-success">' + response.success_replace + '</div>');
                    }
                    else if (typeof response.error_replace !== 'undefined') {
                        form.html('<div class="alert alert-danger">' + response.error_replace + '</div>');
                    }
                    else if (typeof response.notice_replace !== 'undefined') {
                        form.html('<div class="alert alert-warning">' + response.notice_replace + '</div>');
                    }

                    if (typeof response.captcha_unique_id !== 'undefined') {
                        form.find('[name="captcha_unique_id"]').val(response.captcha_unique_id);
                    }
                    if (typeof response.captcha_image !== 'undefined') {
                        form.find('img.captcha-image').attr('src', 'data:image/png;base64,' + response.captcha_image);
                    }

                    if (typeof response.personal_link !== 'undefined' &&
                        typeof response.personal_link.template !== 'undefined' &&
                        typeof response.personal_link.data !== 'undefined') {

                        m('nav .authorisation_link').replace(prepare_view(response.personal_link));
                        m('.modal .close').event_fire('click');
                        m('nav .personal_link [data-m-action]').init();
                    }
                    else if (typeof response.authorisation_link !== 'undefined' &&
                        typeof response.authorisation_link.template !== 'undefined' &&
                        typeof response.authorisation_link.data !== 'undefined') {

                        m('nav .personal_link').replace(prepare_view(response.authorisation_link));
                        m('nav .authorisation_link [data-m-action]').init();

                        m.cookies('authorize', null);
                        m.cookies('weua_token', null);
                    }

                    if (typeof response.remove_sidebar !== 'undefined' && m('#sidebar').length > 0 && m('#__sidebar_toggle .wrapper-menu').length > 0) {
                        m('#sidebar').remove();
                        m('#__sidebar_toggle .wrapper-menu').remove();
                    }

                    /**
                     * Updates authorization tokens and run callback to widgets
                     */
                    if (typeof response.token !== 'undefined') {

                        m.cookies('authorize', response.token);
                        m.cookies('weua_token', response.token);

                        // Call `onsuccess` function to widget
                        if (typeof form.first.data !== 'undefined' && typeof form.first.data.onsuccess === 'function') {

                            console.log(form.first.data.onsuccess);

                            form.first.data.onsuccess.apply(form, [response.token]);
                        }
                    }

                    if (typeof response.modal_close !== 'undefined' && m('.modal.active .close').length > 0) {
                        m('.modal.active .close').event_fire('click');
                    }

                    if (typeof response.redirect !== 'undefined') {
                        window.location.href = response.redirect;
                        return true;
                    }

                    if (typeof response.sidebar !== 'undefined' && typeof response.sidebar_toggle !== 'undefined') {

                        console.log(prepare_view(response.sidebar));
                        console.log(prepare_view(response.sidebar_toggle));

                        m('#content-page').before(prepare_view(response.sidebar));
                        m('#__sidebar_toggle').append(prepare_view(response.sidebar_toggle));
                    }

                }
            });
        };

    next_button.on('click', next);
    reset_button.on('click', reset);
    form.on('submit', submit);

    form.find('[required], [data-required], [pattern], [minlength], [maxlength]').on('input', input);
};