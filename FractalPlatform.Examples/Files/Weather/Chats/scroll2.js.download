if (typeof m == 'undefined') {
    var m = function () {};
    m.fn = m.prototype = {};
}

m.fn.scroll2 = function(context) {

    if (typeof context == 'undefined' || context === null || !(context instanceof m))
        return false;

    let
        top = this.data.top || 0,
        scroll_link = this,
        context_id = context.attr('id');

    this.on('click', function(e) {
        e.preventDefault();

        if (context_id !== null) {
            context = m('#' + context_id);
        }

        let offset_top = typeof context.first.getBoundingClientRect === 'undefined' ?
            context.first.offsetTop :
            context.first.getBoundingClientRect().top;

        document.documentElement.scrollBy({top: offset_top - parseInt(top), left: 0, behavior: 'smooth'})
    });

    if (this.attr('data-m-auto-hide') !== null) {

        m(document).on('scroll', function(event){

            let visible = event.srcElement.scrollingElement.scrollTop > top || document.documentElement.scrollTop > top;

            scroll_link.css({
                visibility: visible ? 'visible' : 'hidden',
                opacity: visible ? 1 : 0
            });
        });
    }

    return true;
};