if (typeof m == 'undefined') {
    var m = function () {};
    m.fn = m.prototype = {};
}

m.fn.password_show = function(field) {

    this.on('click', function(e){
        e.preventDefault();

        m(this).class({active: ':toggle'});

        field.first.setAttribute('type', m(this).class('active') ? 'text' : 'password');
    });
};